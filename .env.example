# OKX API 凭据 — 本地开发用
# 复制此文件为 .env 并填入真实值；.env 已在 .gitignore 中，不会被提交
# 在 OKX 后台 → API 管理 创建 Key 后填入
# 建议：如仅做行情监控，创建时关闭「交易」和「提币」权限，只勾「只读」

OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# Vercel 部署时不需要 .env，改用：
#   vercel env add OKX_API_KEY production
#   vercel env add OKX_SECRET_KEY production
#   vercel env add OKX_PASSPHRASE production
